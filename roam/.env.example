# Copy this file to .env and fill in your API keys
# Both are FREE to obtain — no credit card needed

# ── Unsplash (destination photos) ─────────────────────────────────────────────
# Sign up at: https://unsplash.com/developers
# Create an app → copy the "Access Key"
VITE_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# ── Amadeus (live flight + hotel prices) ──────────────────────────────────────
# Sign up at: https://developers.amadeus.com
# Create an app in "Self-Service" → copy Client ID and Client Secret
# The sandbox (test) environment is free and has realistic price data
VITE_AMADEUS_CLIENT_ID=your_amadeus_client_id_here
VITE_AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_here
